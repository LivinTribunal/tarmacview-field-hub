    },
    "backend/app/models": {
      "allowedImports": ["app.core"]
    },
    "backend/app/core": {
      "allowedImports": []
    }
  },
  "docsDrift": {
    "trackedDocs": [
      "README.md",
      "docs/**"
    ],
    "maxStaleDays": 14,
    "requireUpdateWithCodeChange": false,
    "exemptPatterns": [
      "**/*.test.*",
      "backend/tests/**",
      "**/__pycache__/**"
