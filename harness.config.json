    },
    "tier2": {
      "name": "medium",
      "description": "Business logic, features, refactors, and test changes",
      "patterns": [
        "backend/app/**",
        "frontend/src/**",
        "backend/tests/**",
        "frontend/src/**/*.test.*",
        "backend/requirements.txt",
        "frontend/package.json",
        "docker-compose.yml",
        "backend/pyproject.toml"
      ],
      "requiredChecks": [
        "lint",
        "type-check",
        "test",
        "build"
      ],
      "mergePolicy": {
        "minApprovals": 1,
        "requireReviewAgent": true,
        "allowSelfMerge": false
      },
      "evidenceRequirements": [
        "tests-pass",
        "lint-clean",
        "type-check-clean"
      ]
    },
    "tier3": {
      "name": "high",
      "description": "Core trajectory algorithm, safety validation, flight plan output, and database migrations",
      "patterns": [
        "**/trajectory*",
        "**/safety_validator*",
        "**/flight_plan*",
        "**/migrations/versions/*"
      ],
      "requiredChecks": [
        "lint",
        "type-check",
        "test",
        "build",
        "structural-tests",
        "harness-smoke",
        "manual-approval"
      ],
      "mergePolicy": {
        "minApprovals": 2,
        "requireReviewAgent": true,
        "allowSelfMerge": false
      },
      "evidenceRequirements": [
        "tests-pass",
        "lint-clean",
        "type-check-clean",
        "manual-review"
      ]
    }
  },
  "commands": {
    "test": "cd backend && pytest && cd ../frontend && npx vitest run",
    "build": "cd frontend && npm run build",
    "lint": "cd backend && ruff check . && ruff format --check . && cd ../frontend && npm run lint",
    "typeCheck": "cd frontend && npx tsc --noEmit"
  },
  "shaDiscipline": {
    "enabled": true,
    "enforceExactSha": true,
    "rejectStaleReviews": true,
    "description": "All CI gates pin to exact commit SHA from the risk policy gate"
  },
