# database
POSTGRES_DB=tarmacview
POSTGRES_USER=tarmacview
POSTGRES_PASSWORD=tarmacview

# backend
DATABASE_URL=postgresql://tarmacview:tarmacview@postgres:5432/tarmacview
JWT_SECRET=change-me-in-production-minimum-256-bits
CORS_ORIGINS=["http://localhost"]

# frontend (build-time)
VITE_CESIUM_ION_TOKEN=

# optional - openaip API key for in-app "add airport by ICAO" lookups.
# the bundled seed already ships 3 demo airports (LZIB/LZKZ/LZPP),
# so the app boots and runs end-to-end without this. set it only if you want
# to add more airports through the coordinator UI. get a free key at
# https://openaip.net. left empty here so the file is safe to commit / share.
OPENAIP_API_KEY=

# optional - per-point ground elevation fallback for airports with no DEM uploaded.
# when enabled, takeoff/landing markers and PAPI POI z-coordinates are sampled
# from Open-Elevation instead of the single airport.elevation constant.
# disabled by default so test runs and offline deployments don't depend on
# outbound network. closed-network deployments should leave this off and rely
# on per-airport DEM uploads instead. see OPERATIONS.md "Per-Point Elevation"
# for the full opt-in flow.
#
# this env var is only the bootstrap default for fresh installs - once a super
# admin saves the toggle under Super-admin → System Settings the DB-backed
# `elevation_api_fallback_enabled` row in `system_settings` wins. flipping the
# env var here has no effect on a database that already has the row.
ELEVATION_API_FALLBACK_ENABLED=false

# field profile (docker compose --profile field up) - see docs/specs/FIELD-HUB.md

# shared secret for fieldhub<->backend service calls. empty disables the
# integration: the hub's internal endpoints answer 503 and the backend's
# field-link status reports no hub. generate a random value for field
# deployments, e.g. `openssl rand -hex 32`. never commit a real value.
FIELDHUB_SHARED_SECRET=

# backend -> fieldhub proxy. empty url means no hub in this deployment.
# inside compose use the service address + the local CA mounted at
# /certs/fieldhub; the FIELDHUB_SHARED_SECRET above authenticates the call.
# FIELDHUB_URL=https://fieldhub:8443
# FIELDHUB_CA=/certs/fieldhub/ca.crt
FIELDHUB_URL=
FIELDHUB_CA=

# device-facing mqtt address handed to pilot at login. must be the laptop's
# static lan ip on the travel router - never a compose hostname.
# FIELDHUB_MQTT_DEVICE_ADDR=ssl://192.168.8.100:8883
FIELDHUB_MQTT_DEVICE_ADDR=

# pilot login account for the hub's manage api. login is rejected while the
# password is empty. never commit a real value.
FIELDHUB_PILOT_USERNAME=pilot
FIELDHUB_PILOT_PASSWORD=

# dji developer app bound to the platform (developer.dji.com -> Cloud API
# application). the pilot 2 connect page verifies these via jsbridge before
# login; the page reports unconfigured while they are empty. never commit
# real values.
FIELDHUB_DJI_APP_ID=
FIELDHUB_DJI_APP_KEY=
FIELDHUB_DJI_APP_LICENSE=

# signing key for the hub's x-auth-token jwts - override the dev default in
# the field, e.g. `openssl rand -hex 32`. (empty falls back to the dev default)
# FIELDHUB_JWT_SECRET=

# minio root credentials - local-LAN defaults, override for field deployments
MINIO_ROOT_USER=tarmacview
MINIO_ROOT_PASSWORD=tarmacview-minio
