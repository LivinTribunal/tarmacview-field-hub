# copy to emulator/.env.emulator and fill in. never commit the real file.

# pilot login account the connect page / web login uses. login is rejected
# while the password is empty.
FIELDHUB_PILOT_USERNAME=pilot
FIELDHUB_PILOT_PASSWORD=pilot-emulator

# shared secret the seed-wayline.sh script authenticates with
FIELDHUB_SHARED_SECRET=emulator-secret

# dji developer app (developer.dji.com -> Cloud API application). the connect
# page's license step verifies these via jsbridge; without them /pilot/config
# returns an error and the flow stops at "DJI license". license verification
# needs internet at least once.
FIELDHUB_DJI_APP_ID=
FIELDHUB_DJI_APP_KEY=
FIELDHUB_DJI_APP_LICENSE=

# minio root credentials (defaults match the compose file)
MINIO_ROOT_USER=tarmacview
MINIO_ROOT_PASSWORD=tarmacview-minio

# host-side smoke test only (no emulator): sign device-facing urls for
# localhost so curl can follow them. leave UNSET for real BlueStacks runs -
# it then defaults to http://10.0.2.2:8080.
# FIELDHUB_MINIO_DEVICE_ENDPOINT=http://localhost:8080
